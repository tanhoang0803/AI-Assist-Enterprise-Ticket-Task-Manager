# ============================================================
# AI-Assist Enterprise Ticket & Task Manager — .env.example
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# ────────────────────────────────────────────
# App
# ────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ────────────────────────────────────────────
# Frontend
# ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────
# Database (PostgreSQL via Supabase)
# ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ticketmanager
# For Supabase:
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ────────────────────────────────────────────
# Redis (BullMQ)
# ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# For Upstash Redis:
# REDIS_URL=rediss://:[password]@[host].upstash.io:6380

# ────────────────────────────────────────────
# Auth0
# ────────────────────────────────────────────
# Backend
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# Frontend (Next.js Auth0 SDK)
AUTH0_SECRET=a-long-random-secret-for-session-encryption
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# ────────────────────────────────────────────
# JWT (if using local JWT, not Auth0 only)
# ────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ────────────────────────────────────────────
# AI — Hugging Face
# ────────────────────────────────────────────
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────
# AI — OpenAI (fallback)
# ────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ────────────────────────────────────────────
# Slack
# ────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ────────────────────────────────────────────
# Email — SendGrid
# ────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=AI-Assist Manager

# ────────────────────────────────────────────
# Google Calendar
# ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/integrations/calendar/callback

# ────────────────────────────────────────────
# Stripe (optional demo)
# ────────────────────────────────────────────
STRIPE_SECRET_KEY=<your-stripe-test-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ────────────────────────────────────────────
# Turborepo (optional remote caching)
# ────────────────────────────────────────────
TURBO_TEAM=
TURBO_TOKEN=
